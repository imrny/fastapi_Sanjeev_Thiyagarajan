from pydantic import BaseModel,Field
from datetime import datetime, timezone
from typing import Optional


class PostBase(BaseModel):
    title: str
    content: str
    published: bool = True

class PostCreate(PostBase):
    pass

class PostUpdate(PostBase):
    title: str
    content: str

class Post(PostBase):
    id: int
    created_at: datetime

    class Config:
        orm_mode = True
